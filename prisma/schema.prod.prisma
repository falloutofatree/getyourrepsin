// Production Prisma schema — PostgreSQL
// Used for Digital Ocean App Platform deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model StaffInfo {
  id             String   @id // gid://shopify/StaffMember/123
  shop           String
  firstName      String   @default("")
  lastName       String   @default("")
  email          String   @default("")
  canSendInvoice Boolean  @default(false)
  lastSeen       DateTime @default(now())

  @@index([shop])
}

model StaffAssignment {
  id                  String   @id @default(cuid())
  shop                String
  staffId             String   // gid://shopify/StaffMember/123
  companyLocationId   String   // gid://shopify/CompanyLocation/456
  createdAt           DateTime @default(now())

  @@unique([shop, staffId, companyLocationId])
  @@index([shop, staffId])
}

model FilterableCollection {
  id           String   @id @default(cuid())
  shop         String
  collectionId String
  title        String   @default("")
  numericId    String   @default("")
  createdAt    DateTime @default(now())

  @@unique([shop, collectionId])
  @@index([shop])
}

model AppSettings {
  id    String @id @default(cuid())
  shop  String
  key   String
  value String

  @@unique([shop, key])
  @@index([shop])
}
